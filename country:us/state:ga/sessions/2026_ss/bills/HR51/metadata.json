  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "A RESOLUTION urging Governor Brian P. Kemp to immediately release funds withheld through executive budget disregards issued against House Bill 974, the Fiscal Year 2027 General Appropriations Act; affirming the exclusive constitutional authority of the General Assembly over the appropriation of public funds; recognizing the bipartisan effort of House and Senate leadership in crafting a balanced budget; urging the Governor to honor the will of the legislature; and for other purposes."
    }
  ],
